{
    "$schema": "https://raw.githubusercontent.com/design-tokens/spec/main/schemas/token-schema.json",
    "// ==========================================================================": "",
    "// 1. PRIMITIVES – raw values, rarely used directly                        ": "",
    "// ==========================================================================": "",
    "color": {
        "gray": {
            "50": {
                "$value": "#fafafa",
                "$type": "color"
            },
            "100": {
                "$value": "#f5f5f5",
                "$type": "color"
            },
            "200": {
                "$value": "#e5e5e5",
                "$type": "color"
            },
            "300": {
                "$value": "#d4d4d4",
                "$type": "color"
            },
            "400": {
                "$value": "#a3a3a3",
                "$type": "color"
            },
            "500": {
                "$value": "#737373",
                "$type": "color"
            },
            "600": {
                "$value": "#525252",
                "$type": "color"
            },
            "700": {
                "$value": "#404040",
                "$type": "color"
            },
            "800": {
                "$value": "#262626",
                "$type": "color"
            },
            "900": {
                "$value": "#171717",
                "$type": "color"
            },
            "950": {
                "$value": "#0a0a0a",
                "$type": "color"
            }
        },
        "blue": {
            "500": {
                "$value": "#3b82f6",
                "$type": "color"
            },
            "600": {
                "$value": "#2563eb",
                "$type": "color"
            },
            "700": {
                "$value": "#1d4ed8",
                "$type": "color"
            }
        },
        "indigo": {
            "500": {
                "$value": "#6366f1",
                "$type": "color"
            },
            "600": {
                "$value": "#8b5cf6",
                "$type": "color"
            }
        },
        "red": {
            "600": {
                "$value": "#dc2626",
                "$type": "color"
            }
        },
        "green": {
            "500": {
                "$value": "#10b981",
                "$type": "color"
            }
        }
    },
    "font": {
        "family": {
            "sans": {
                "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
                "$type": "fontFamily"
            },
            "mono": {
                "$value": "'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace",
                "$type": "fontFamily"
            }
        },
        "size": {
            "2xs": {
                "$value": "0.625rem",
                "$type": "dimension"
            },
            "xs": {
                "$value": "0.75rem",
                "$type": "dimension"
            },
            "sm": {
                "$value": "0.875rem",
                "$type": "dimension"
            },
            "base": {
                "$value": "1rem",
                "$type": "dimension"
            },
            "lg": {
                "$value": "1.125rem",
                "$type": "dimension"
            },
            "xl": {
                "$value": "1.25rem",
                "$type": "dimension"
            },
            "2xl": {
                "$value": "1.5rem",
                "$type": "dimension"
            }
        },
        "weight": {
            "normal": {
                "$value": "400",
                "$type": "fontWeight"
            },
            "medium": {
                "$value": "500",
                "$type": "fontWeight"
            },
            "semibold": {
                "$value": "600",
                "$type": "fontWeight"
            },
            "bold": {
                "$value": "700",
                "$type": "fontWeight"
            },
            "extrabold": {
                "$value": "800",
                "$type": "fontWeight"
            }
        }
    },
    "spacing": {
        "0": {
            "$value": "0",
            "$type": "dimension"
        },
        "1": {
            "$value": "0.25rem",
            "$type": "dimension"
        },
        "2": {
            "$value": "0.5rem",
            "$type": "dimension"
        },
        "3": {
            "$value": "0.75rem",
            "$type": "dimension"
        },
        "4": {
            "$value": "1rem",
            "$type": "dimension"
        },
        "5": {
            "$value": "1.25rem",
            "$type": "dimension"
        },
        "6": {
            "$value": "1.5rem",
            "$type": "dimension"
        },
        "8": {
            "$value": "2rem",
            "$type": "dimension"
        },
        "10": {
            "$value": "2.5rem",
            "$type": "dimension"
        },
        "12": {
            "$value": "3rem",
            "$type": "dimension"
        }
    },
    "radius": {
        "sm": {
            "$value": "0.125rem",
            "$type": "dimension"
        },
        "md": {
            "$value": "0.375rem",
            "$type": "dimension"
        },
        "lg": {
            "$value": "0.5rem",
            "$type": "dimension"
        },
        "xl": {
            "$value": "0.75rem",
            "$type": "dimension"
        },
        "2xl": {
            "$value": "1rem",
            "$type": "dimension"
        },
        "full": {
            "$value": "9999px",
            "$type": "dimension"
        }
    },
    "shadow": {
        "sm": {
            "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
            "$type": "shadow"
        },
        "md": {
            "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
            "$type": "shadow"
        },
        "lg": {
            "$value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
            "$type": "shadow"
        },
        "xl": {
            "$value": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
            "$type": "shadow"
        }
    },
    "// ==========================================================================": "",
    "// 2. GLOBAL SEMANTIC TOKENS – purpose-driven names                        ": "",
    "// ==========================================================================": "",
    "semantic": {
        "color": {
            "text": {
                "primary": {
                    "$value": "{color.gray.900}",
                    "$type": "color"
                },
                "secondary": {
                    "$value": "{color.gray.600}",
                    "$type": "color"
                },
                "tertiary": {
                    "$value": "{color.gray.500}",
                    "$type": "color"
                },
                "disabled": {
                    "$value": "{color.gray.400}",
                    "$type": "color"
                },
                "inverse": {
                    "$value": "{color.gray.50}",
                    "$type": "color"
                }
            },
            "bg": {
                "surface": {
                    "$value": "{color.gray.50}",
                    "$type": "color"
                },
                "subtle": {
                    "$value": "{color.gray.100}",
                    "$type": "color"
                },
                "muted": {
                    "$value": "{color.gray.200}",
                    "$type": "color"
                }
            },
            "border": {
                "default": {
                    "$value": "{color.gray.300}",
                    "$type": "color"
                },
                "strong": {
                    "$value": "{color.gray.400}",
                    "$type": "color"
                }
            },
            "accent": {
                "base": {
                    "$value": "{color.blue.500}",
                    "$type": "color"
                },
                "hover": {
                    "$value": "{color.blue.600}",
                    "$type": "color"
                },
                "active": {
                    "$value": "{color.blue.700}",
                    "$type": "color"
                },
                "tech": {
                    "$value": "{color.indigo.500}",
                    "$type": "color"
                }
            },
            "danger": {
                "base": {
                    "$value": "{color.red.600}",
                    "$type": "color"
                }
            },
            "success": {
                "base": {
                    "$value": "{color.green.500}",
                    "$type": "color"
                }
            }
        },
        "modal": {
            "backdrop": {
                "color": {
                    "$value": "rgba(15, 23, 42, 0.7)",
                    "$type": "color"
                },
                "blur": {
                    "$value": "blur(8px)",
                    "$type": "backdrop-filter"
                }
            },
            "surface": {
                "$value": "#1e293b",
                "$type": "color"
            },
            "border": {
                "$value": "rgba(255, 255, 255, 0.06)",
                "$type": "color"
            },
            "shadow": {
                "$value": "{shadow.xl}",
                "$type": "shadow"
            }
        }
    },
    "// ==========================================================================": "",
    "// 3. COMPONENT TOKENS – reusable building blocks                           ": "",
    "// ==========================================================================": "",
    "component": {
        "modal": {
            "max-width": {
                "$value": "min(92vw, 960px)",
                "$type": "dimension"
            },
            "max-height": {
                "$value": "90vh",
                "$type": "dimension"
            },
            "padding": {
                "horizontal": {
                    "$value": "{spacing.8}",
                    "$type": "dimension"
                },
                "vertical": {
                    "$value": "{spacing.6}",
                    "$type": "dimension"
                },
                "mobile": {
                    "$value": "{spacing.5}",
                    "$type": "dimension"
                }
            },
            "header": {
                "padding": {
                    "$value": "20px 24px",
                    "$type": "dimension"
                },
                "gap": {
                    "$value": "{spacing.4}",
                    "$type": "dimension"
                }
            },
            "content": {
                "gap": {
                    "$value": "{spacing.6}",
                    "$type": "dimension"
                }
            },
            "footer": {
                "padding": {
                    "$value": "16px 24px",
                    "$type": "dimension"
                },
                "gap": {
                    "$value": "{spacing.4}",
                    "$type": "dimension"
                }
            },
            "close": {
                "size": {
                    "$value": "40px",
                    "$type": "dimension"
                },
                "padding": {
                    "$value": "8px",
                    "$type": "dimension"
                },
                "top": {
                    "$value": "16px",
                    "$type": "dimension"
                },
                "right": {
                    "$value": "16px",
                    "$type": "dimension"
                },
                "mobile": {
                    "size": {
                        "$value": "44px",
                        "$type": "dimension"
                    },
                    "top": {
                        "$value": "12px",
                        "$type": "dimension"
                    },
                    "right": {
                        "$value": "12px",
                        "$type": "dimension"
                    }
                }
            }
        },
        "card": {
            "bg": {
                "$value": "#1e293b",
                "$type": "color"
            },
            "border": {
                "$value": "rgba(255, 255, 255, 0.03)",
                "$type": "color"
            },
            "radius": {
                "$value": "{radius.xl}",
                "$type": "dimension"
            },
            "padding": {
                "$value": "{spacing.6}",
                "$type": "dimension"
            }
        },
        "button": {
            "radius": {
                "$value": "{radius.md}",
                "$type": "dimension"
            },
            "padding-horizontal": {
                "$value": "{spacing.6}",
                "$type": "dimension"
            }
        },
        "input": {
            "radius": {
                "$value": "{radius.md}",
                "$type": "dimension"
            },
            "padding": {
                "$value": "12px 16px",
                "$type": "dimension"
            },
            "height": {
                "$value": "2.75rem",
                "$type": "dimension"
            }
        },
        "icon": {
            "size": {
                "sm": {
                    "$value": "1rem",
                    "$type": "dimension"
                },
                "md": {
                    "$value": "1.25rem",
                    "$type": "dimension"
                },
                "lg": {
                    "$value": "1.5rem",
                    "$type": "dimension"
                }
            }
        }
    },
    "// ==========================================================================": "",
    "// 4. MOTION & EFFECTS – animations & visual polish                        ": "",
    "// ==========================================================================": "",
    "motion": {
        "transition": {
            "fast": {
                "$value": "all 0.2s ease",
                "$type": "transition"
            },
            "normal": {
                "$value": "all 0.3s cubic-bezier(0.4, 0, 0.2, 1)",
                "$type": "transition"
            },
            "slow": {
                "$value": "all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)",
                "$type": "transition"
            },
            "modal-enter": {
                "$value": "opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)",
                "$type": "transition"
            },
            "backdrop-enter": {
                "$value": "opacity 0.25s ease",
                "$type": "transition"
            }
        },
        "transform": {
            "hover-lift": {
                "$value": "translateY(-4px)",
                "$type": "string"
            },
            "hover-lift-strong": {
                "$value": "translateY(-8px)",
                "$type": "string"
            }
        }
    },
    "effect": {
        "backdrop-blur": {
            "$value": "blur(8px)",
            "$type": "backdrop-filter"
        },
        "gradient-tech": {
            "$value": "linear-gradient(135deg, {color.indigo.500} 0%, {color.indigo.600} 100%)",
            "$type": "string"
        }
    }
}